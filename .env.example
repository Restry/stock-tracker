# Supabase Database
NEXT_PUBLIC_SUPABASE_URL=https://db.dora.restry.cn
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# DeepSeek decision engine
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# News/search enrichment
TAVILY_API_KEY=your_tavily_api_key

# Cron/security
CRON_SECRET=your_cron_secret

# Optional: OpenClaw observer script target
TRADER_APP_URL=http://localhost:3001

# Notifications (optional - all disabled by default)
# Telegram bot notifications
NOTIFY_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
NOTIFY_TELEGRAM_CHAT_ID=your_telegram_chat_id
# Webhook notifications (Slack, Discord, etc.)
NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
